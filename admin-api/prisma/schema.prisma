// ─── Wagering race (leaderboard) ─────────────────────────────────────────────

enum RaceStatus {
  SCHEDULED
  ACTIVE
  PAUSED
  FINISHED
  CANCELLED
}

model Race {
  id             String     @id @default(uuid())
  startTime      DateTime
  endTime        DateTime
  status         RaceStatus @default(SCHEDULED)
  /// When true, race window may still run but leaderboard credits are frozen (wagers ignored).
  trackingPaused Boolean    @default(false)
  /// "24h" | "7d" | "custom" — informational for admin UI.
  raceWindow     String?

  /// Optional denormalized total of `RaceReward.rewardAmount` for the race (1–10).
  totalPrizePool Decimal?   @db.Decimal(14, 2)

  participants RaceParticipant[]
  rewards      RaceReward[]

  @@index([status, endTime(sort: Desc)])
  @@index([status, startTime(sort: Desc)])
}

model RaceParticipant {
  id            String   @id @default(uuid())
  raceId        String
  userUsername  String
  wageredAmount Decimal  @default(0) @db.Decimal(14, 2)
  /// Tie-break: earlier `updatedAt` wins when `wageredAmount` ties. Managed in application layer (not @updatedAt).
  updatedAt     DateTime @default(now())
  /// Populated when the race finishes — avoids recounting for historical rank.
  finalRank     Int?

  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userUsername], references: [username], onDelete: Cascade)

  @@unique([raceId, userUsername])
  @@index([raceId, wageredAmount(sort: Desc), updatedAt(sort: Asc)])
  @@index([userUsername])
}

/// Prize schedule for positions 1–10 (same rows used for active display and finished history).
model RaceReward {
  id           String  @id @default(uuid())
  raceId       String
  position     Int
  rewardAmount Decimal @db.Decimal(14, 2)

  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@unique([raceId, position])
  @@index([raceId])
}

// ─── Level / milestone “reward” cases (separate from shop `Case`) ─────────────

model RewardCaseDefinition {
  id             String   @id @default(uuid())
  slug           String   @unique
  position       Int
  imageUrl       String
  title          String
  isRakebackCase Boolean  @default(false)
  milestoneLevel Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  isActive             Boolean @default(true)
  receivesWagerKeys    Boolean @default(false)
  wagerCoinsPerKey     Int     @default(100)
  wagerKeysMaxPerEvent Int     @default(10)
  levelUpKeysOverride  Int?

  /// Minimum user level required to unlock (open) this case. 0 = no restriction.
  requiredLevel Int @default(0)

  /// XP needed per milestone key grant (null = feature disabled).
  xpMilestoneThreshold      Int?
  /// Maximum keys granted per single XP-milestone event (caps burst from large bets). Default 10.
  xpMilestoneMaxKeysPerEvent Int @default(10)

  poolItems         RewardCaseItem[]
  userKeyEntries    UserKey[]
  rewardOpens       RewardCaseOpen[]
  milestoneProgress RewardCaseMilestoneProgress[]

  @@index([position])
  @@map("reward_case_definitions")
}

model RewardCaseItem {
  id           String    @id @default(uuid())
  rewardCaseId String
  petId        Int
  weight       Int
  sortOrder    Int       @default(0)
  variant      Variant[] @default([])

  case RewardCaseDefinition @relation(fields: [rewardCaseId], references: [id], onDelete: Cascade)
  pet  pets                  @relation(fields: [petId], references: [id])

  @@index([rewardCaseId])
  @@index([petId])
  @@map("reward_case_items")
}

model UserKey {
  id           String              @id @default(uuid())
  userUsername String
  rewardCaseId String
  quantity     Int
  source       UserRewardKeySource
  referenceId  String?
  createdAt    DateTime            @default(now())

  user User                 @relation(fields: [userUsername], references: [username], onDelete: Cascade)
  case RewardCaseDefinition @relation(fields: [rewardCaseId], references: [id], onDelete: Restrict)

  @@index([userUsername, rewardCaseId])
  @@index([userUsername, createdAt(sort: Desc)])
  @@map("user_keys")
}

model RewardCaseOpen {
  id           String   @id @default(uuid())
  userUsername String
  rewardCaseId String
  itemsReceived Json
  createdAt    DateTime @default(now())

  user User                 @relation(fields: [userUsername], references: [username], onDelete: Cascade)
  case RewardCaseDefinition @relation(fields: [rewardCaseId], references: [id], onDelete: Restrict)

  @@index([userUsername, rewardCaseId, createdAt(sort: Desc)])
  @@map("reward_cases")
}

/// Tracks how many XP-milestone keys have already been granted per user per case.
model RewardCaseMilestoneProgress {
  id           String   @id @default(uuid())
  userUsername String
  rewardCaseId String
  keysGranted  Int      @default(0)
  updatedAt    DateTime @updatedAt

  user User                 @relation(fields: [userUsername], references: [username], onDelete: Cascade)
  case RewardCaseDefinition @relation(fields: [rewardCaseId], references: [id], onDelete: Cascade)

  @@unique([userUsername, rewardCaseId])
  @@index([userUsername])
  @@map("reward_case_milestone_progress")
}