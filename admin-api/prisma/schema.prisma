// ─── Game economy (theoretical house edge / RTP for analytics & cached game API reads) ─

/// Versioned target economics per product slice. Realized profit still comes from `GameHistory`.
/// Lookup active row: `effectiveTo` null, latest `effectiveFrom` for (`gameType`, optional `caseId`, optional `variantKey`).
/// DICE uses one row per period (same theoretical edge for OVER and UNDER).
model GameEconomyConfig {
  id           String        @id @default(uuid())
  gameType     GameType
  /// When set, `gameType` should be CASE — edge for that case listing only.
  caseId       String?
  /// Optional app-defined slice when edge varies inside one `gameType` (e.g. Mines `5x5-3`, Crash curve `v2`, jackpot fee tier). Leave null for a single global edge per game.
  variantKey   String?

  /// Long-run fraction of stake the model retains (e.g. 0.04 = 4%). Theoretical RTP ≈ 1 − houseEdge.
  houseEdge Decimal @db.Decimal(10, 8)

  effectiveFrom DateTime  @default(now())
  /// Null means still active until superseded; set end timestamp when replacing with a newer config.
  effectiveTo   DateTime?

  notes    String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case Case? @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([gameType, effectiveFrom(sort: Desc)])
  @@index([gameType, caseId, variantKey, effectiveFrom(sort: Desc)])
  @@index([gameType, effectiveTo, effectiveFrom(sort: Desc)])
  @@index([caseId])
  @@map("game_economy_configs")
}

// ─── Cases (loot boxes) ─────────────────────────────────────────────────────────

model Case {
  id        String      @id @default(uuid())
  slug      String      @unique
  name      String
  imageUrl  String?
  price     Decimal     @db.Decimal(12, 2)
  variant   CaseVariant @default(STANDARD)
  catalogCategory CaseCatalogCategory @default(AMP)
  /// Continuous risk 0–100 (e.g. 22 = low; higher = riskier). Map to 4 bands in application logic.
  riskLevel Decimal     @default(0) @db.Decimal(5, 2)
  isActive  Boolean     @default(true)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  items CaseItem[]
  opens CaseOpenHistory[]
  economyConfigs GameEconomyConfig[]

  @@index([isActive, sortOrder])
  @@index([slug])
  @@index([variant])
  @@index([catalogCategory])
  @@map("cases")
}

/// Weighted pool entry: roll maps to cumulative weights using provably fair `normalizedRoll` on CaseOpenHistory.
model CaseItem {
  id        String @id @default(uuid())
  caseId    String
  petId     Int
  weight    Int
  sortOrder Int    @default(0)
  variant   Variant[] @default([])

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  pet  pets @relation(fields: [petId], references: [id])

  wins CaseOpenHistory[]

  @@index([caseId])
  @@index([petId])
  @@map("case_items")
}

model CaseOpenHistory {
  id             String  @id @default(uuid())
  userUsername   String
  caseId         String
  wonCaseItemId  String
  /// Which row when opening multiple cases in one action (0-based).
  openBatchIndex Int     @default(0)

  pricePaid Decimal @db.Decimal(12, 2)
  wonItemValue Decimal @db.Decimal(12, 2) @default(0)

  // Provably fair (same shape as DiceBet / user seed nonce chain)
  clientSeed       String  @db.VarChar(64)
  serverSeedHash   String  @db.VarChar(64)
  nonce            Int
  /// Deterministic value in [0, 1) from seeds + nonce; pick item by cumulative weight.
  normalizedRoll   Decimal @db.Decimal(24, 8)
  /// Populated after server seed rotation / reveal so users can verify past opens.
  serverSeed       String? @db.VarChar(128)

  seedRotationHistoryId String?
  seedRotationHistory   SeedRotationHistory? @relation(fields: [seedRotationHistoryId], references: [id])
  gameHistoryId         String?              @unique
  parentHistory         GameHistory?         @relation(fields: [gameHistoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  user    User     @relation(fields: [userUsername], references: [username], onDelete: Cascade)
  case    Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  wonItem CaseItem @relation(fields: [wonCaseItemId], references: [id], onDelete: Restrict)

  @@index([userUsername])
  @@index([caseId])
  @@index([caseId, createdAt])
  @@index([createdAt(sort: Desc)])
  @@index([userUsername, createdAt(sort: Desc)])
  @@index([serverSeedHash])
  @@map("case_open_history")
}

