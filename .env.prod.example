# Production — copy to `.env.prod` and fill secrets (never commit `.env.prod`).
# Run: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# Nginx HTTPS: requires ./nginx/certs/fullchain.pem and ./nginx/certs/privkey.pem on the host
# (e.g. Let's Encrypt, or `mkdir -p nginx/certs && openssl req -x509 -nodes -newkey rsa:2048
# -keyout nginx/certs/privkey.pem -out nginx/certs/fullchain.pem -days 365 -subj "/CN=admin.example.com"` for testing).
#
# Postgres TLS: if the DB needs a custom CA (e.g. DigitalOcean), put the PEM at
# ./certs/db_cert/db_cert.crt (mounted into the admin-api container). Override path with
# DATABASE_SSL_CA_PATH=/path/in/container. If the file is absent, SSL still applies when
# DATABASE_URL contains sslmode=require (or set DATABASE_SSL=true) using the default CA store.
# Non-TLS DB: use sslmode=disable in DATABASE_URL or DATABASE_SSL=false.

# Postgres — admin-api + Next server (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_POSTGRES_HOST:5432/YOUR_DB?sslmode=require

# Redis: set REDIS_URL — or REDIS_HOST + REDIS_PASSWORD (optional REDIS_PORT; password URL-encoded when built).
REDIS_URL=redis://:PASSWORD@YOUR_REDIS_HOST:6379

ADMIN_API_PORT=4005
NODE_ENV=production

JWT_SECRET=CHANGE_ME_MIN_32_RANDOM_BYTES
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Baked into the web image at build time (see docker-compose.prod.yml build.args)
NEXT_PUBLIC_ADMIN_API_URL=/api
ADMIN_API_INTERNAL_URL=http://admin-api:4005

# Next.js standalone server (must match nginx upstream web:PORT)
WEB_PORT=4006

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
