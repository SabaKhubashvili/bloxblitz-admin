# Production — copy to `.env.prod` and fill secrets (never commit `.env.prod`).
# Run: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# Nginx HTTPS: requires ./nginx/certs/fullchain.pem and ./nginx/certs/privkey.pem on the host.
# Generate test certs: `bash nginx/certs/generate-self-signed.sh` (use Let's Encrypt in real prod).
#
# Postgres TLS (DigitalOcean, etc.):
# - Recommended: download your provider's CA bundle, save as ./certs/db_cert/db_cert.crt (see docker-compose.prod.yml mount).
# - If you see "self-signed certificate in certificate chain" / P1011: the CA file is missing or wrong.
# - Temporary workaround (not ideal for production): DATABASE_SSL_REJECT_UNAUTHORIZED=false
# Non-TLS DB: DATABASE_SSL=false or add sslmode=disable to DATABASE_URL.

# Postgres — admin-api + Next server (Prisma). sslmode in URL is stripped when app supplies TLS options; you can omit it.
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_POSTGRES_HOST:5432/YOUR_DB?sslmode=require

# Optional explicit TLS overrides
# DATABASE_SSL_CA_PATH=/app/certs/db_cert/db_cert.crt
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Redis: required in this compose file — there is no `redis` service; the default hostname `redis` will not work.
# Use your managed Redis URL (TLS often uses rediss://).
REDIS_URL=redis://:PASSWORD@YOUR_REDIS_HOST:6379

ADMIN_API_PORT=4005
NODE_ENV=production

JWT_SECRET=CHANGE_ME_MIN_32_RANDOM_BYTES
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Baked into the web image at build time (see docker-compose.prod.yml build.args)
NEXT_PUBLIC_ADMIN_API_URL=/api
ADMIN_API_INTERNAL_URL=http://admin-api:4005

# Next.js standalone server (must match nginx upstream web:PORT)
WEB_PORT=4006

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
