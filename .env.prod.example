# Production — copy to `.env.prod` and fill secrets (never commit `.env.prod`).
# Run: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# TLS: place fullchain.pem and privkey.pem in nginx/certs/ (see nginx/certs/gen-self-signed.sh for local testing only).

# Postgres — admin-api + Next server (Prisma). Use TLS if offered: ?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_POSTGRES_HOST:5432/YOUR_DB

# Redis: set REDIS_URL — or REDIS_HOST + REDIS_PASSWORD (optional REDIS_PORT; password URL-encoded when built).
REDIS_URL=redis://:PASSWORD@YOUR_REDIS_HOST:6379

ADMIN_API_PORT=4005
NODE_ENV=production

JWT_SECRET=CHANGE_ME_MIN_32_RANDOM_BYTES
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Baked into the web image at build time (see docker-compose.prod.yml build.args)
NEXT_PUBLIC_ADMIN_API_URL=/api
ADMIN_API_INTERNAL_URL=http://admin-api:4005

# Next.js standalone server (must match nginx upstream web:PORT)
WEB_PORT=4006

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
